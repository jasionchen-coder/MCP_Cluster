APP_NAME=mcp-shared-services
APP_ENV=dev
DATABASE_URL=sqlite+aiosqlite:///./mcp_shared_services.db
# 本地 PostgreSQL 示例：
# DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/mcp_shared_services
ARK_API_KEY=
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
ARK_DEFAULT_MODEL=ep-xxxxxxxx
ARK_TOPIC_MODEL=ep-xxxxxxxx
ARK_IMAGE_MODEL=doubao-seedream-4-5-251128
RAG_VECTOR_ENABLED=true
RAG_EMBEDDING_DIMENSION=384
# Production should use a stable Fernet key or a strong passphrase.
SECRET_ENCRYPTION_KEY=
MCP_TRANSPORT=streamable-http
MCP_HOST=127.0.0.1
MCP_PORT=8401
MCP_STREAMABLE_HTTP_PATH=/mcp
LOG_LEVEL=INFO
